NODE_ENV=development
PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/clinicDB?retryWrites=true&w=majority&appName=Cluster0
MONGO_CONNECT_RETRIES=5
MONGO_DNS_SERVERS=1.1.1.1,8.8.8.8
JWT_SECRET=replace_with_a_long_random_secret_for_production
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
